#!/usr/bin/env bash
set -euo pipefail

# EasyPseudogene - Automated Pseudogene Identification Pipeline
# Usage: easypseudogene --proteins PROTEINS.fa --genome GENOME.fa --threads N [options]

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
EASYPSEUDOGENE_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"
LIB_DIR="${EASYPSEUDOGENE_DIR}/lib"
CONFIG_DIR="${EASYPSEUDOGENE_DIR}/config"

# Ensure we're using absolute paths
EASYPSEUDOGENE_DIR="$(cd "${EASYPSEUDOGENE_DIR}" && pwd)"
LIB_DIR="${EASYPSEUDOGENE_DIR}/lib"
CONFIG_DIR="${EASYPSEUDOGENE_DIR}/config"

# Default values
THREADS=""
PROTEINS=""
GENOME=""
SPECIES=""
OUTPUT_DIR=""
WISECONFIGDIR="${WISECONFIGDIR:-}"
WISEPATH="${WISEPATH:-}"

# Parse arguments
usage() {
    cat <<EOF
EasyPseudogene - Automated Pseudogene Identification Pipeline

Usage: easypseudogene [OPTIONS]

Required:
  --proteins FILE       Reference protein FASTA file
  --genome FILE         Target genome FASTA file
  --threads N           Number of threads

Optional:
  --species NAME        Species name (default: auto-detect from genome filename)
  --output DIR          Output directory (default: ./easypseudogene_output)
  --wiseconfig DIR      WISECONFIGDIR for GeneWise (if not in PATH)
  --wisepath DIR        PATH to GeneWise binaries (if not in PATH)
  --whitelist FILE      Whitelist of reference transcript IDs (one per line)
  --config FILE         Configuration file (default: config/default.conf)
  --skip-genewise       Skip GeneWise step (use existing results)
  --skip-filter         Skip filtering step (use existing results)
  --visualize           Generate HTML visualization report after completion
  --help                Show this help message

Examples:
  easypseudogene --proteins human.proteins.fa --genome dolphin.fa --threads 96
  easypseudogene --proteins human.proteins.fa --genome dolphin.fa --threads 96 --whitelist ref_list.txt

EOF
}

while [[ $# -gt 0 ]]; do
    case $1 in
        --proteins)
            PROTEINS="$2"
            shift 2
            ;;
        --genome)
            GENOME="$2"
            shift 2
            ;;
        --threads)
            THREADS="$2"
            shift 2
            ;;
        --species)
            SPECIES="$2"
            shift 2
            ;;
        --output)
            OUTPUT_DIR="$2"
            shift 2
            ;;
        --wiseconfig)
            WISECONFIGDIR="$2"
            shift 2
            ;;
        --wisepath)
            WISEPATH="$2"
            shift 2
            ;;
        --whitelist)
            REF_WHITELIST="$2"
            shift 2
            ;;
        --config)
            CONFIG_FILE="$2"
            shift 2
            ;;
        --skip-genewise)
            SKIP_GENEWISE=1
            shift
            ;;
        --skip-filter)
            SKIP_FILTER=1
            shift
            ;;
        --visualize)
            GENERATE_VISUALIZATION=1
            shift
            ;;
        --help|-h)
            usage
            exit 0
            ;;
        *)
            echo "ERROR: Unknown option: $1" >&2
            usage
            exit 1
            ;;
    esac
done

# Check required arguments
if [[ -z "${PROTEINS}" || -z "${GENOME}" || -z "${THREADS}" ]]; then
    echo "ERROR: Missing required arguments" >&2
    usage
    exit 1
fi

# Check if files exist
if [[ ! -f "${PROTEINS}" ]]; then
    echo "ERROR: Protein file not found: ${PROTEINS}" >&2
    exit 1
fi

if [[ ! -f "${GENOME}" ]]; then
    echo "ERROR: Genome file not found: ${GENOME}" >&2
    exit 1
fi

# Auto-detect species name if not provided
if [[ -z "${SPECIES}" ]]; then
    SPECIES=$(basename "${GENOME}" .fa | sed 's/\.fa$//' | sed 's/\.fasta$//' | sed 's/_chr$//' | sed 's/_genome$//')
    echo "Auto-detected species name: ${SPECIES}"
fi

# Set output directory
if [[ -z "${OUTPUT_DIR}" ]]; then
    OUTPUT_DIR="./easypseudogene_output"
fi

# Load configuration
CONFIG_FILE="${CONFIG_FILE:-${CONFIG_DIR}/default.conf}"
if [[ -f "${CONFIG_FILE}" ]]; then
    source "${CONFIG_FILE}"
fi

# Export paths
export EASYPSEUDOGENE_DIR LIB_DIR
export PROTEINS GENOME SPECIES OUTPUT_DIR THREADS
export REF_WHITELIST="${REF_WHITELIST:-}"

# Set GeneWise paths if explicitly provided via --wisepath
if [[ -n "${WISEPATH}" ]]; then
    export PATH="${WISEPATH}:${PATH}"
fi

# Auto-detect WISECONFIGDIR if not already set (via env var or --wiseconfig)
if [[ -z "${WISECONFIGDIR}" ]]; then
    # Priority 1: look relative to the genewise binary (works for conda, brew, system installs)
    if command -v genewise >/dev/null 2>&1; then
        _gw_bin="$(command -v genewise)"
        _gw_prefix="$(cd "$(dirname "${_gw_bin}")/.." && pwd)"
        if [[ -d "${_gw_prefix}/share/wise2/wisecfg" ]]; then
            WISECONFIGDIR="${_gw_prefix}/share/wise2/wisecfg"
        fi
    fi
    # Priority 2: active conda environment
    if [[ -z "${WISECONFIGDIR}" && -n "${CONDA_PREFIX:-}" ]]; then
        if [[ -d "${CONDA_PREFIX}/share/wise2/wisecfg" ]]; then
            WISECONFIGDIR="${CONDA_PREFIX}/share/wise2/wisecfg"
        fi
    fi
    # Priority 3: common system-wide locations
    if [[ -z "${WISECONFIGDIR}" ]]; then
        for _candidate in /usr/share/wise2/wisecfg /usr/local/share/wise2/wisecfg; do
            if [[ -d "${_candidate}" ]]; then
                WISECONFIGDIR="${_candidate}"
                break
            fi
        done
    fi
fi
if [[ -n "${WISECONFIGDIR}" ]]; then
    export WISECONFIGDIR
fi

# Check dependencies
echo "Checking dependencies..."
for cmd in mmseqs miniprot samtools python3 awk sort comm; do
    if ! command -v "${cmd}" >/dev/null 2>&1; then
        echo "ERROR: Missing dependency: ${cmd}" >&2
        exit 1
    fi
done

# Check GeneWise if not skipping
if [[ -z "${SKIP_GENEWISE:-}" ]]; then
    if ! command -v genewise >/dev/null 2>&1; then
        echo "ERROR: GeneWise (genewise) not found in PATH." >&2
        echo "  Install via conda:  conda install -c bioconda wise2" >&2
        echo "  Or specify manually: --wisepath /path/to/wise2/bin" >&2
        exit 1
    fi
    if [[ -z "${WISECONFIGDIR}" ]]; then
        echo "ERROR: WISECONFIGDIR could not be detected automatically." >&2
        echo "  Specify it with:  --wiseconfig /path/to/wisecfg" >&2
        exit 1
    fi
fi

echo ""
echo "=========================================="
echo "EasyPseudogene - Pseudogene Identification"
echo "=========================================="
echo "Proteins:      ${PROTEINS}"
echo "Genome:        ${GENOME}"
echo "Species:       ${SPECIES}"
echo "Threads:       ${THREADS}"
echo "Output:        ${OUTPUT_DIR}"
echo "WISECONFIGDIR: ${WISECONFIGDIR:-<not set>}"
echo "=========================================="
echo ""

# Create output directory structure
mkdir -p "${OUTPUT_DIR}/${SPECIES}"/{mmseqs,miniprot,regions,genewise,post_genewise_filter,logs,tmp}

# Step 1: Pre-GeneWise screening (mmseqs2 + miniprot)
if [[ ! -f "${OUTPUT_DIR}/${SPECIES}/miniprot/${SPECIES}.paf" ]]; then
    echo "[1/3] Running pre-GeneWise screening (mmseqs2 + miniprot)..."
    bash "${EASYPSEUDOGENE_DIR}/scripts/run_screening.sh" \
        --proteins "${PROTEINS}" \
        --genome "${GENOME}" \
        --species "${SPECIES}" \
        --output "${OUTPUT_DIR}" \
        --threads "${THREADS}"
else
    echo "[1/3] Pre-GeneWise screening already done, skipping..."
fi

# Step 2: GeneWise
if [[ -z "${SKIP_GENEWISE:-}" ]]; then
    if [[ ! -f "${OUTPUT_DIR}/${SPECIES}/genewise/pseudogene-genewise.txt" ]]; then
        echo "[2/3] Running GeneWise..."
        bash "${EASYPSEUDOGENE_DIR}/scripts/run_genewise.sh" \
            --proteins "${PROTEINS}" \
            --genome "${GENOME}" \
            --species "${SPECIES}" \
            --output "${OUTPUT_DIR}" \
            --threads "${THREADS}"
    else
        echo "[2/3] GeneWise already done, skipping..."
    fi
else
    echo "[2/3] Skipping GeneWise (--skip-genewise)"
fi

# Step 3: Post-GeneWise filtering
if [[ -z "${SKIP_FILTER:-}" ]]; then
    echo "[3/3] Running post-GeneWise filtering..."
    bash "${EASYPSEUDOGENE_DIR}/scripts/run_filtering.sh" \
        --proteins "${PROTEINS}" \
        --species "${SPECIES}" \
        --output "${OUTPUT_DIR}" \
        --whitelist "${REF_WHITELIST:-}"
else
    echo "[3/3] Skipping filtering (--skip-filter)"
fi

echo ""
echo "=========================================="
echo "EasyPseudogene completed successfully!"
echo "=========================================="
echo ""
echo "Results:"
echo "  High-confidence pseudogenes: ${OUTPUT_DIR}/${SPECIES}/post_genewise_filter/high_confidence_pseudogene_ids.txt"
echo "  All putative pseudogenes: ${OUTPUT_DIR}/${SPECIES}/post_genewise_filter/putative_pseudogene_ids.txt"
echo ""

# Generate visualization if requested
if [[ -n "${GENERATE_VISUALIZATION:-}" ]]; then
    echo "[Visualization] Generating HTML report..."
    genewise_file="${OUTPUT_DIR}/${SPECIES}/genewise/pseudogene-genewise.txt"
    visualization_file="${OUTPUT_DIR}/${SPECIES}/genewise_visualization.html"
    
    if [[ -f "${genewise_file}" ]]; then
        python3 "${LIB_DIR}/visualize_genewise.py" \
            --genewise "${genewise_file}" \
            --output "${visualization_file}"
        echo "  Visualization saved to: ${visualization_file}"
    else
        echo "  WARNING: GeneWise output not found, skipping visualization" >&2
    fi
    echo ""
fi
